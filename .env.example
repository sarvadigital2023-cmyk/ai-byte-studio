# AI Byte Studio — environment variables
#
# NEVER commit real values. On Vercel, set these in:
#   Project Settings → Environment Variables → add each key → redeploy.
# For local development, copy this file to `.env` and fill in the values.

# Supabase (cloud sync, auth, history, storage)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI providers
VITE_HEYGEN_API_KEY=
VITE_RUNWAY_API_KEY=
VITE_ELEVENLABS_API_KEY=
